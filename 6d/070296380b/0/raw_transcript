111111111111111111111111111111111\"),\n   134\t\t\torphan: plumbing.NewHash(\"3333333333333333333333333333333333333333\"),\n   135\t\t}\n   136\t\n   137\t\tplans, err := BuildReplicationPlans(desired, targetRefs, managed, PlanConfig{Prune: true})\n   138\t\tif err != nil {\n   139\t\t\tt.Fatalf(\"BuildReplicationPlans: %v\", err)\n   140\t\t}\n   141\t\n   142\t\t// The returned plans should include the orphan delete...\n   143\t\tvar sawDelete bool\n   144\t\tfor _, p := range plans {\n   145\t\t\tif p.TargetRef == orphan && p.Action == ActionDelete {\n   146\t\t\t\tsawDelete = true\n   147\t\t\t}\n   148\t\t}\n   149\t\tif !sawDelete {\n   150\t\t\tt.Fatalf(\"expected prune delete for orphan, got plans=%+v\", plans)\n   151\t\t}\n   152\t\n   153\t\t// ...but the caller's managed map must remain unchanged.\n   154\t\tif len(managed) != 1 {\n   155\t\t\tt.Fatalf(\"caller's managed map was mutated: %+v\", managed)\n   156\t\t}\n   157\t\tif _, ok := managed[orphan]; ok {\n   158\t\t\tt.Fatalf(\"orphan leaked into caller's managed map\")\n   159\t\t}\n   160\t}\n   161\t\n   162\tfunc TestValidateMappingsRejectsDuplicateTargets(t *testing.T) {\n   163\t\t_, err := validation.ValidateMappings([]RefMapping{\n   164\t\t\t{Source: \"main\", Target: \"stable\"},\n   165\t\t\t{Source: \"release\", Target: \"stable\"},\n   166\t\t})\n   167\t\tif err == nil {\n   168\t\t\tt.Fatalf(\"expected error for duplicate target\")\n   169\t\t}\n   170\t}\n   171\t\n   172\tfunc TestValidateMappingsRejectsCrossKind(t *testing.T) {\n   173\t\t_, err := validation.ValidateMappings([]RefMapping{\n   174\t\t\t{Source: \"refs/heads/main\", Target: \"refs/tags/main\"},\n   175\t\t})\n   176\t\tif err == nil {\n   177\t\t\tt.Fatalf(\"expected error for cross-kind mapping\")\n   178\t\t}\n   179\t}\n   180\t\n   181\tfunc TestValidateMappingsRejectsMixedQualification(t *testing.T) {\n   182\t\t_, err := validation.ValidateMappings([]RefMapping{\n   183\t\t\t{Source: \"refs/heads/main\", Targ