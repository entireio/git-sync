 533\t}\n   534\t\n   535\tfunc (w *wrappedMultiRC) Read(p []byte) (int, error) { return w.Reader.Read(p) }\n   536\t\n   537\t// chainPosition returns the index of hash in chain, or -1 if not found.\n   538\tfunc chainPosition(chain []plumbing.Hash, hash plumbing.Hash) int {\n   539\t\tfor i, h := range chain {\n   540\t\t\tif h == hash {\n   541\t\t\t\treturn i\n   542\t\t\t}\n   543\t\t}\n   544\t\treturn -1\n   545\t}\n   546\t\n   547\t// subdivideCheckpoints splits each remaining checkpoint range in half using\n   548\t// the full commit chain. Called when a batch push is rejected for exceeding\n   549\t// the target's body-size limit. Returns the expanded checkpoint list; if no\n   550\t// split is possible (ranges are already 1 commit), returns the input unchanged.\n   551\tfunc subdivideCheckpoints(chain []plumbing.Hash, current plumbing.Hash, remaining []plumbing.Hash) []plumbing.Hash {\n   552\t\tchainIdx := make(map[plumbing.Hash]int, len(chain))\n   553\t\tfor i, h := range chain {\n   554\t\t\tchainIdx[h] = i\n   555\t\t}\n   556\t\tcurIdx, ok := chainIdx[current]\n   557\t\tif !ok && !current.IsZero() {\n   558\t\t\treturn remaining\n   559\t\t}\n   560\t\tif current.IsZero() {\n   561\t\t\tcurIdx = -1\n   562\t\t}\n   563\t\n   564\t\texpanded := make([]plumbing.Hash, 0, len(remaining)*2)\n   565\t\tprev := curIdx\n   566\t\tfor _, cp := range remaining {\n   567\t\t\tcpIdx, ok := chainIdx[cp]\n   568\t\t\tif !ok {\n   569\t\t\t\texpanded = append(expanded, cp)\n   570\t\t\t\tcontinue\n   571\t\t\t}\n   572\t\t\tgap := cpIdx - prev\n   573\t\t\tif gap > 1 {\n   574\t\t\t\tmidIdx := prev + gap/2\n   575\t\t\t\texpanded = append(expanded, chain[midIdx])\n   576\t\t\t}\n   577\t\t\texpanded = append(expanded, cp)\n   578\t\t\tprev = cpIdx\n   579\t\t}\n   580\t\treturn expanded\n   581\t}\n   582\t\n   583\tfunc evenCheckpoints(chain []plumbing.Hash, numBatches int) []plumbing.Hash {\n   584\t\tif numBatches <= 1 || len(chain) <= 1 || numBatches >= len(chain) {\n   585\t\t\treturn []plumbing.Hash{chain[len(chain)-1]}\n   586\t\t}\n   587\t\tcheckpoints := make([]plumbing.Hash, 0, numBatches)\n   588\t\tbatchSize := len(chain) / numBatches\n   589\t\tfor i := 0; i < numBatches-1; i++ {\n   590\t\t\tidx := (i+1)*batchSize - 1\n   591\t\t\tif idx >= len(chain)-1 {\n   592\t\t\t\tbreak\n   593\t\t\t}\n   594\t\t\tcheckpoints = append(checkpoints, chain[idx])\n   595\t\t}\n   596\t\tcheckpoints = append(checkpoints, chain[len(chain)-1])\n   597\t\treturn checkpoints\n   598\t}\n   599\t\n   600\tfunc packReaderForCheckpoint(\n   601\t\tctx context.Context,\n   602\t\tp Params,\n   603\t\tbatch plannedBatch,\n   604\t\tcheckpoint plumbing.Hash,\n   605\t\tcurrent plumbing.Hash,\n   606\t\tcompletedRefs map[plumbing.ReferenceName]plumbing.Hash,\n   607\t\tbatchLimit int64,\n   608\t) (io.ReadCloser, error) {\n   609\t\tdesired := singleGP(batch.Plan.SourceRef, batch.TempRef, checkpoint)\n   610\t\t// Merge the current checkpoint (within this branch) with any\n   611\t\t// already-completed branch tips so the source can delta-compress\n   612\t\t// against objects the target already has from previous branches.\n   613\t\thaves := planner.CopyRefHashMap(completedRefs)\n   614\t\tif !current.IsZero() {\n   615\t\t\thaves[batch.TempRef] = current\n   616\t\t}\n   617\t\tpackReader, err := p.SourceService.FetchPack(ctx, p.SourceConn, desired, haves)\n   618\t\tif err != nil {\n   619\t\t\treturn nil, err\n   620\t\t}\n   621\t\treturn gitproto.LimitPackReader(packReader, batchLimit), nil\n   622\t}\n   623\t\n   624\t// --- GitHub preflight ---\n   625\t\n   626\tfunc githubBatchLimit(ctx context.Context, p Params) (int64, bool) {\n   627\t\tif p.TargetMaxPack > 0 || p.SourceConn == nil || p.SourceConn.Endpoint == nil {\n   628\t\t\treturn 0, false\n   629\t\t}\n   630\t\tif p.SourceService == nil || !p.SourceService.SupportsBootstrapBatch() {\n   631\t\t\treturn 0, false\n   632\t\t}\n   633\t\trepoSizeKB, ok := lookupGitHub