sh.String()})\n   130\t\t}\n   131\t\treturn out\n   132\t}\n   133\t\n   134\tfunc FromSyncResult(result syncer.Result) SyncResult {\n   135\t\tout := SyncResult{\n   136\t\t\tRefs: make([]RefResult, 0, len(result.Plans)),\n   137\t\t\tCounts: SyncCounts{\n   138\t\t\t\tApplied: result.Pushed,\n   139\t\t\t\tSkipped: result.Skipped,\n   140\t\t\t\tBlocked: result.Blocked,\n   141\t\t\t\tDeleted: result.Deleted,\n   142\t\t\t},\n   143\t\t\tExecution: ExecutionSummary{\n   144\t\t\t\tDryRun:             result.DryRun,\n   145\t\t\t\tProtocol:           result.Protocol,\n   146\t\t\t\tRelay:              result.Relay,\n   147\t\t\t\tMode:               result.RelayMode,\n   148\t\t\t\tReason:             result.RelayReason,\n   149\t\t\t\tBootstrapSuggested: result.BootstrapSuggested,\n   150\t\t\t\tBatch: BatchSummary{\n   151\t\t\t\t\tEnabled: result.Batching,\n   152\t\t\t\t\tPlanned: result.PlannedBatchCount,\n   153\t\t\t\t\tDone:    result.BatchCount,\n   154\t\t\t\t},\n   155\t\t\t},\n   156\t\t\tStats:       FromStats(result.Stats),\n   157\t\t\tMeasurement: FromMeasurement(result.Measurement),\n   158\t\t}\n   159\t\tfor _, plan := range result.Plans {\n   160\t\t\tout.Refs = append(out.Refs, RefResult{\n   161\t\t\t\tBranch:     plan.Branch,\n   162\t\t\t\tSourceRef:  plan.SourceRef.String(),\n   163\t\t\t\tTargetRef:  plan.TargetRef.String(),\n   164\t\t\t\tSourceHash: HashString(plan.SourceHash),\n   165\t\t\t\tTargetHash: HashString(plan.TargetHash),\n   166\t\t\t\tKind:       RefKind(plan.Kind),\n   167\t\t\t\tAction:     Action(plan.Action),\n   168\t\t\t\tReason:     plan.Reason,\n   169\t\t\t})\n   170\t\t}\n   171\t\treturn out\n   172\t}\n   173\t\n   174\tfunc FromStats(stats syncer.Stats) Stats {\n   175\t\tout := Stats{Enabled: stats.Enabled, Items: make(map[string]*ServiceStats, len(stats.Items))}\n   176\t\tfor key, item := range stats.Items {\n   177\t\t\tcopyItem := *item\n   178\t\t\tout.Items[key] = &ServiceStats{\n   179\t\t\t\tName:          copyItem.Name,\n   180\t\t\t\tRequests:      copyItem.Requests,\n   181\t\t\t\tRequestBytes:  copyItem.RequestBytes,\n   182\t\t\t\tResponseBytes: copyItem.ResponseBytes,\n   183\t\t\t\tWants:         copyItem.Wants,\n   184\t\t\t\tHaves:         copyItem.Haves,\n   185\t\t\t\tCommands:      copyItem.Commands,\n   186\t\t\t}\n   187\t\t}\n   188\t\treturn out\n   189\t}\n   190\t\n   191\tfunc FromMeasurement(m syncer.Measurement) Measurement {\n   192\t\treturn Measurement{\n   193\t\t\tEnabled:            m.Enabled,\n   194\t\t\tElapsedMillis:      m.ElapsedMillis,\n   195\t\t\tPeakAllocBytes:     m.PeakAllocBytes,\n   196\t\t\tPeakHeapInuseBytes: m.PeakHeapInuseBytes,\n   197\t\t\tTotalAllocBytes:    m.TotalAllocBytes,\n   198\t\t\tGCCount:            m.GCCount,\n   199\t\t}\n   200\t}\n   201\t\n   202\tfunc HashString(hash plumbing.Hash) string {\n   203\t\tif hash.IsZero() {\n   204\t\t\treturn \"\"\n   205\t\t}\n   206\t\treturn hash.String()\n   207\t}\n     1\tpackage gitsync\n     2\t\n     3\timport (\n     4\t\t\"context\"\n     5\t\t\"fmt\"\n     6\t\t\"net/http\"\n     7\t\n     8\t\t\"github.com/soph/git-sync/internal/validation\"\n     9\t\t\"github.com/soph/git-sync/pkg/gitsync/internalbridge\"\n    10\t)\n    11\t\n    12\t// Options configures a Client. It is intentionally small in the first public cut.\n    13\ttype Options struct {\n    14\t\tHTTPClient *http.Client\n    15\t\tAuth       AuthProvider\n    16\t}\n    17\t\n    18\t// Client provides the public orchestration API for git-sync.\n    19\ttype Client struct {\n    20\t\thttpClient *http.Client\n    21\t\tauth       AuthProvider\n    22\t}\n    23\t\n    24\t// New constructs a new Client.\n    25\tfunc New(opts Options) *Client {\n    26\t\treturn &Client{httpClient: opts.HTTPClient, auth: opts.Auth}\n    27\t}\n    28\t\n    29\t// Probe inspects a source remote and optional target remote.\n    30\tfunc (c *Client) Probe(ctx context.Context, req ProbeRequest) (ProbeResult, error) {\n    31\t\tif err := req.Validate(); err != nil {\n    32\t\t\treturn ProbeResult{}, err\n    33\t\t}\n    34\t\tcfg, err := c.buildProbeConfig(ctx, req)\n    35\t\tif err != nil {\n    36\t\t\treturn ProbeResult{}, err\n    37\t\t}\n    38\t\tresult, err := internalbridge.Probe(ctx, cfg)\n    39\t\tif err != nil {\n    40\t\t\treturn ProbeResult{}, err\n    41\t\t}\n    42\t\treturn internalbridge.FromProbeResult(result), nil\n    43\t}\n    44\t\n    45\t// Plan computes ref actions without pushing.\n    46\tfunc (c *Client) Plan(ctx context.Context, req PlanRequest) (PlanResult, error) {\n    47\t\tif err := req.Validate(); err != nil {\n    48\t\t\treturn PlanResult{}, err\n    49\t\t}\n    50\t\tcfg, err := c.buildSyncConfig(ctx, req.Source, req.Target, req.Scope, req.Policy, req.CollectStats, true)\n    51\t\tif err != nil {\n    52\t\t\treturn PlanResult{}, err\n    53\t\t}\n    54\t\tresult, err := internalbridge.Run(ctx, cfg)\n    55\t\tif err != nil {\n    56\t\t\treturn PlanResult{}, err\n    57\t\t}\n    58\t\treturn internalbridge.FromSyncResult(result), nil\n    59\t}\n    60\t\n    61\t// Sync executes a sync between two remotes.\n    62\tfunc (c *Client) Sync(ctx context.Context, req SyncRequest) (SyncResult, error) {\n    63\t\tif err := req.Validate(); err != nil {\n    64\t\t\treturn SyncResult{}, err\n    65\t\t}\n    66\t\tcfg, err := c.buildSyncConfig(ctx, req.Source, req.Target, req.Scope, req.Policy, req.CollectStats, false)\n    67\t\tif err != nil {\n    68\t\t\treturn SyncResult{}, err\n    69\t\t}\n    70\t\tresult, err := internalbridge.Run(ctx, cfg)\n    71\t\tif err != nil {\n    72\t\t\treturn SyncResult{}, err\n    73\t\t}\n    74\t\treturn internalbridge.FromSyncResult(result), nil\n    75\t}\n    76\t\n    77\tfunc (c *Client) buildProbeConfig(ctx context.Context, req ProbeRequest) (internalbridge.Config, error) {\n    78\t\tsourceAuth, err := c.authFor(ctx, req.Source, SourceRole)\n    79\t\tif err != nil {\n    80\t\t\treturn internalbridge.Config{}, err\n    81\t\t}\n    82\t\tvar target *internalbridge.Endpoint\n    83\t\ttargetAuth := internalbridge.EndpointAuth{}\n    84\t\tif req.Target != nil {\n    85\t\t\tresolvedTargetAuth, err := c.authFor(ctx, *req.Target, TargetRole)\n    86\t\t\tif err != nil {\n    87\t\t\t\treturn internalbridge.Config{}, err\n    88\t\t\t}\n    89\t\t\ttarget = ptr(bridgeEndpoint(*req.Target))\n    90\t\t\ttargetAuth = bridgeEndpointAuth(resolvedTargetAuth)\n    91\t\t}\n    92\t\treturn internalbridge.ProbeConfig(\n    93\t\t\tbridgeEndpoint(req.Source),\n    94\t\t\tbridgeEndpointAuth(sourceAuth),\n    95\t\t\ttarget,\n    96\t\t\ttargetAuth,\n    97\t\t\tinternalbridge.ProtocolMode(req.Protocol),\n    98\t\t\treq.IncludeTags,\n    99\t\t\treq.CollectStats,\n   100\t\t\tc.httpClient,\n   101\t\t), nil\n   102\t}\n   103\t\n   104\tfunc (c *Client) buildSyncConfig(ctx context.Context, source Endpoint, target Endpoint, scope RefScope, policy SyncPolicy, collectStats, dryRun bool) (internalbridge.Config, error) {\n   105\t\tsourceAuth, err := c.authFor(ctx, source, SourceRole)\n   106\t\tif err != nil {\n   107\t\t\treturn internalbridge.Config{}, err\n   108\t\t}\n   109\t\ttargetAuth, err := c.authFor(ctx, target, TargetRole)\n   110\t\tif err != nil {\n   111\t\t\treturn internalbridge.Config{}, err\n   112\t\t}\n   113\t\treturn internalbridge.SyncConfig(\n   114\t\t\tbridgeEndpoint(source),\n   115\t\t\tbridgeEndpointAuth(sourceAuth),\n   116\t\t\tbridgeEndpoint(target),\n   117\t\t\tbridgeEndpointAuth(targetAuth),\n   118\t\t\tbridgeScope(scope),\n   119\t\t\tbridgePolicy(policy),\n   120\t\t\tcollectStats,\n   121\t\t\tdryRun,\n   122\t\t\tc.httpClient,\n   123\t\t), nil\n   124\t}\n   125\t\n   126\tfunc (c *Client) authFor(ctx context.Context, endpoint Endpoint, role EndpointRole) (EndpointAuth, error) {\n   127\t\tif c.auth == nil {\n   128\t\t\treturn EndpointAuth{}, nil\n   129\t\t}\n   130\t\treturn c.auth.AuthFor(ctx, endpoint, role)\n   131\t}\n   132\t\n   133\tfunc (r SyncRequest) Validate() error {\n   134\t\tif r.Source.URL == \"\" {\n   135\t\t\treturn fmt.Errorf(\"source URL is required\")\n   136\t\t}\n   137\t\tif r.Target.URL == \"\" {\n   138\t\t\treturn fmt.Errorf(\"target URL is required\")\n   139\t\t}\n   140\t\tif _, err := validation.NormalizeProtocolMode(string(r.Policy.Protocol)); err != nil {\n   141\t\t\treturn err\n   142\t\t}\n   143\t\tif _, err := validation.ValidateMappings(validationMappings(r.Scope.Mappings)); err != nil {\n   144\t\t\treturn err\n   145\t\t}\n   146\t\treturn nil\n   147\t}\n   148\t\n   149\tfunc (r PlanRequest) Validate() error {\n   150\t\tif r.Source.URL == \"\" {\n   151\t\t\treturn fmt.Errorf(\"source URL is required\")\n   152\t\t}\n   153\t\tif r.Target.URL == \"\" {\n   154\t\t\treturn fmt.Errorf(\"target URL is required\")\n   155\t\t}\n   156\t\tif _, err := validation.NormalizeProtocolMode(string(r.Policy.Protocol)); err != nil {\n   157\t\t\treturn err\n   158\t\t}\n   159\t\tif _, err := validation.ValidateMappings(validationMappings(r.Scope.Mappings)); err != nil {\n   160\t\t\treturn err\n   161\t\t}\n   162\t\treturn nil\n   163\t}\n   164\t\n   165\tfunc (r ProbeRequest) Validate() error {\n   166\t\tif r.Source.URL == \"\" {\n   167\t\t\treturn fmt.Errorf(\"source URL is required\")\n   168\t\t}\n   169\t\tif r.Target != nil && r.Target.URL == \"\" {\n   170\t\t\treturn fmt.Errorf(\"target URL is required when target endpoint is provided\")\n   171\t\t}\n   172\t\tif _, err := validation.NormalizeProtocolMode(string(r.Protocol)); err != nil {\n   173\t\t\treturn err\n   174\t\t}\n   175\t\treturn nil\n   176\t}\n   177\t\n   178\tfunc bridgeEndpoint(ep Endpoint) internalbridge.Endpoint {\n   179\t\treturn internalbridge.Endpoint{URL: ep.URL}\n   180\t}\n   181\t\n   182\tfunc bridgeEndpointAuth(auth EndpointAuth) internalbridge.EndpointAuth {\n   183\t\treturn internalbridge.EndpointAuth{\n   184\t\t\tUsername:      auth.Username,\n   185\t\t\tToken:         auth.Token,\n   186\t\t\tBearerToken:   auth.BearerToken,\n   187\t\t\tSkipTLSVerify: auth.SkipTLSVerify,\n   188\t\t}\n   189\t}\n   190\t\n   191\tfunc bridgeScope(scope RefScope) internalbridge.RefScope {\n   192\t\tmappings := make([]internalbridge.RefMapping, 0, len(scope.Mappings))\n   193\t\tfor _, mapping := range scope.Mappings {\n   194\t\t\tmappings = append(mappings, internalbridge.RefMapping{\n   195\t\t\t\tSource: mapping.Source,\n   196\t\t\t\tTarget: mapping.Target,\n   197\t\t\t})\n   198\t\t}\n   199\t\treturn internalbridge.RefScope{\n   200\t\t\tBranches: append([]string(nil), scope.Branches...),\n   201\t\t\tMappings: mappings,\n   202\t\t}\n   203\t}\n   204\t\n   205\tfunc bridgePolicy(policy SyncPolicy) internalbridge.SyncPolicy {\n   206\t\treturn internalbridge.SyncPolicy{\n   207\t\t\tIncludeTags: policy.IncludeTags,\n   208\t\t\tForce:       policy.Force,\n   209\t\t\tPrune:       policy.Prune,\n   210\t\t\tProtocol:    internalbridge.ProtocolMode(policy.Protocol),\n   211\t\t}\n   212\t}\n   213\t\n   214\tfunc ptr[T any](v T) *T {\n   215\t\treturn &v\n   216\t}\n   217\t\n   218\tfunc validationMappings(mappings []RefMapping) []validation.RefMapping {\n   219\t\tout := make([]validation.RefMapping, 0, len(mappings))\n   220\t\tfor _, mapping := range mappings {\n   221\t\t\tout = append(out, validation.RefMapping{\n   222\t\t\t\tSource: mapping.Source,\n   223\t\t\t\tTarget: mapping.Target,\n   224\t\t\t})\n   225\t\t}\n   226\t\treturn out\n   227\t}\n     1\tpackage unstable\n     2\t\n     3\timport (\n     4\t\t\"context\"\n     5\t\t\"net/http\"\n     6\t\n     7\t\t\"github.com/go-git/go-git/v6/plumbing\"\n     8\t\n     9\t\t\"github.com/soph/git-sync/internal/syncer\"\n    10\t\t\"github.com/soph/git-sync/internal/validation\"\n    11\t\t\"github.com/soph/git-sync/pkg/gitsync\"\n    12\t\t\"github.com/soph/git-sync/pkg/gitsync/internalbridge\"\n    13\t)\n    14\t\n    15\tconst DefaultMaterializedMaxObject