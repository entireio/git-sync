{"parentUuid":"58e8a74b-1793-4a0f-ad83-d0ce0f51596b","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/soph/Work/entire/devenv/git-sync/internal/gitproto/refs.go","snippet":"1\tpackage gitproto\n2\t\n3\timport (\n4\t\t\"bufio\"\n5\t\t\"bytes\"\n6\t\t\"context\"\n7\t\t\"errors\"\n8\t\t\"fmt\"\n9\t\t\"io\"\n10\t\t\"strings\"\n11\t\n12\t\t\"github.com/go-git/go-git/v6/plumbing\"\n13\t\t\"github.com/go-git/go-git/v6/plumbing/format/pktline\"\n14\t\t\"github.com/go-git/go-git/v6/plumbing/protocol/capability\"\n15\t\t\"github.com/go-git/go-git/v6/plumbing/protocol/packp\"\n16\t\t\"github.com/go-git/go-git/v6/plumbing/transport\"\n17\t)\n18\t\n19\t// GitProtocolV2 is the value passed via the Git-Protocol header / GIT_PROTOCOL\n20\t// env var to negotiate protocol v2 with the remote.\n21\tconst GitProtocolV2 = \"version=2\"\n22\t\n23\t// RefService encapsulates the result of source ref discovery and the negotiated\n24\t// protocol, providing methods for subsequent fetch and pack operations.\n25\ttype RefService struct {\n26\t\tProtocol string // \"v1\" or \"v2\"\n27\t\tV1Adv    *packp.AdvRefs\n28\t\tV2Caps   *V2Capabilities\n29\t\t// HeadTarget is the branch that HEAD points to on the source, when\n30\t\t// advertised as a symref. Empty for detached HEAD or when the source\n31\t\t// does not advertise symref information.\n32\t\tHeadTarget plumbing.ReferenceName\n33\t\t// Verbose, when true, streams source-side sideband progress (\"Counting\n34\t\t// objects\", \"Compressing objects\", ...) to stderr and asks the source\n35\t\t// upload-pack to emit progress by not sending the no-progress option.\n36\t\tVerbose bool\n37\t}\n38\t\n39\t// ListSourceRefs discovers refs from the source using the configured protocol mode.\n40\t// Returns the list of refs and a RefService for subsequent operations.\n41\tfunc ListSourceRefs(ctx context.Context, conn Conn, protocolMode string, refPrefixes []string) ([]*plumbing.Reference, *RefService, error) {\n42\t\tswitch protocolMode {\n43\t\tcase \"v1\":\n44\t\t\tadv, refs, err := listSourceRefsV1(ctx, conn)\n45\t\t\tif err != nil {\n46\t\t\t\treturn nil, nil, err\n47\t\t\t}\n48\t\t\treturn refs, &RefService{Protocol: \"v1\", V1Adv: adv, HeadTarget: headTargetFromAdv(adv)}, nil\n49\t\n50\t\tcase \"auto\", \"v2\":\n51\t\t\tdata, err := RequestInfoRefs(ctx, conn, transport.UploadPackService, GitProtocolV2)\n52\t\t\tif err != nil {\n53\t\t\t\tif protocolMode == \"auto\" && isSSHScheme(conn) {\n54\t\t\t\t\trefs, svc, v1Err := listSourceRefsAutoV1(ctx, conn)\n55\t\t\t\t\tif v1Err != nil {\n56\t\t\t\t\t\treturn nil, nil, errors.Join(err, v1Err)\n57\t\t\t\t\t}\n58\t\t\t\t\treturn refs, svc, nil\n59\t\t\t\t}\n60\t\t\t\treturn nil, nil, err\n61\t\t\t}\n62\t\t\tif caps, err := DecodeV2Capabilities(bytes.NewReader(data)); err == nil {\n63\t\t\t\tif !caps.Supports(\"ls-refs\") || !caps.Supports(\"fetch\") {\n64\t\t\t\t\treturn nil, nil, errors.New(\"source does not advertise required protocol v2 commands\")\n65\t\t\t\t}\n66\t\t\t\trefs, headTarget, err := listSourceRefsV2(ctx, conn, caps, refPrefixes)\n67\t\t\t\tif err != nil {\n68\t\t\t\t\treturn nil, nil, err\n69\t\t\t\t}\n70\t\t\t\treturn refs, &RefService{Protocol: \"v2\", V2Caps: caps, HeadTarget: headTarget}, nil\n71\t\t\t}\n72\t\t\tif protocolMode == \"v2\" {\n73\t\t\t\treturn nil, nil, errors.New(\"source did not negotiate protocol v2\")\n74\t\t\t}\n75\t\t\t// Fall back to v1\n76\t\t\tadv, err := decodeV1AdvRefs(data)\n77\t\t\tif err != nil {\n78\t\t\t\treturn nil, nil, err\n79\t\t\t}\n80\t\t\trefs, err := AdvRefsToSlice(adv)\n81\t\t\tif err != nil {\n82\t\t\t\treturn nil, nil, err\n83\t\t\t}\n84\t\t\treturn refs, &RefService{Protocol: \"v1\", V1Adv: adv, HeadTarget: headTargetFromAdv(adv)}, nil\n85\t\n86\t\tdefault:\n87\t\t\treturn nil, nil, fmt.Errorf(\"unsupported protocol mode %q\", protocolMode)\n88\t\t}\n89\t}\n90\t\n91\tfunc listSourceRefsAutoV1(ctx context.Context, conn Conn) ([]*plumbing.Reference, *RefService, error) {\n92\t\tadv, refs, err := listSourceRefsV1(ctx, conn)\n93\t\tif err != nil {\n94\t\t\treturn nil, nil, err\n95\t\t}\n96\t\treturn refs, &RefService{Protocol: \"v1\", V1Adv: adv, HeadTarget: headTargetFromAdv(adv)}, nil\n97\t}\n98\t\n99\tfunc isSSHScheme(conn Conn) bool {\n100\t\tif conn == nil || conn.Endpoint() == nil {\n101\t\t\treturn false\n102\t\t}\n103\t\tswitch conn.Endpoint().Scheme {\n104\t\tcase \"ssh\", \"git+ssh\":\n105\t\t\treturn true\n106\t\t}\n107\t\treturn false\n108\t}\n109\t\n110\t// AdvertisedRefsV1 fetches and decodes v1 advertised refs for the given service.\n111\tfunc AdvertisedRefsV1(ctx context.Context, conn Conn, service string) (*packp.AdvRefs, error) {\n112\t\tdata, err := RequestInfoRefs(ctx, conn, service, \"\")\n113\t\tif err != nil {\n114\t\t\treturn nil, err\n115\t\t}\n116\t\treturn decodeV1AdvRefs(data)\n117\t}\n118\t\n119\t// AdvRefsToSlice converts an AdvRefs to a slice of references.\n120\t//\n121\t// Peeled tag entries (names ending in \"^{}\") are dropped: they are\n122\t// wire-protocol metadata exposing the commit a tag points to, not real refs.\n123\t// Including them in target ref maps causes the planner to schedule a delete\n124\t// for a non-existent ref, which receive-pack rejects with HTTP 400\n125\t// \"invalid reference name\".\n126\tfunc AdvRefsToSlice(ar *packp.AdvRefs) ([]*plumbing.Reference, error) {\n127\t\trefs, err := ar.ResolvedReferences()\n128\t\tif err != nil {\n129\t\t\treturn nil, fmt.Errorf(\"resolved references: %w\", err)\n130\t\t}\n131\t\tout := refs[:0]\n132\t\tfor _, ref := range refs {\n133\t\t\tif ref.Name().IsPeeled() {\n134\t\t\t\tcontinue\n135\t\t\t}\n136\t\t\tout = append(out, ref)\n137\t\t}\n138\t\treturn out, nil\n139\t}\n140\t\n141\t// AdvRefsCaps returns the sorted capability list from an AdvRefs.\n142\tfunc AdvRefsCaps(adv *packp.AdvRefs) []string {\n143\t\tif adv == nil || adv.Capabilities.IsEmpty() {\n144\t\t\treturn nil\n145\t\t}\n146\t\tall := adv.Capabilities.All()\n147\t\titems := make([]string, 0, len(all))\n148\t\tfor _, cap := range all {\n149\t\t\tvalues := adv.Capabilities.Get(cap)\n150\t\t\tif len(values) == 0 {\n151\t\t\t\titems = append(items, cap)\n152\t\t\t\tcontinue\n153\t\t\t}\n154\t\t\tfor _, value := range values {\n155\t\t\t\titems = append(items, cap+\"=\"+value)\n156\t\t\t}\n157\t\t}\n158\t\treturn items\n159\t}\n160\t\n161\tfunc listSourceRefsV1(ctx context.Context, conn Conn) (*packp.AdvRefs, []*plumbing.Reference, error) {\n162\t\tadv, err := AdvertisedRefsV1(ctx, conn, transport.UploadPackService)\n163\t\tif err != nil {\n164\t\t\treturn nil, nil, err\n165\t\t}\n166\t\trefs, err := AdvRefsToSlice(adv)\n167\t\tif err != nil {\n168\t\t\treturn nil, nil, err\n169\t\t}\n170\t\treturn adv, refs, nil\n171\t}\n172\t\n173\tfunc listSourceRefsV2(ctx context.Context, conn Conn, caps *V2Capabilities, prefixes []string) ([]*plumbing.Reference, plumbing.ReferenceName, error) {\n174\t\t// Always include \"HEAD\" so the server returns the symref-target attribute\n175\t\t// for HEAD. Without this, callers that pass only \"refs/heads/\" or\n176\t\t// \"refs/tags/\" prefixes filter HEAD out of the response and lose the\n177\t\t// default-branch hint that bootstrap planning uses as a trunk cutoff.\n178\t\targs := []string{\"peel\", \"symrefs\", \"ref-prefix HEAD\"}\n179\t\tfor _, prefix := range prefixes {\n180\t\t\targs = append(args, \"ref-prefix \"+prefix)\n181\t\t}\n182\t\tbody, err := EncodeCommand(\"ls-refs\", caps.RequestCapabilities(), args)\n183\t\tif err != nil {\n184\t\t\treturn nil, \"\", err\n185\t\t}\n186\t\tdata, err := PostRPC(ctx, conn, transport.UploadPackService, body, true, \"upload-pack ls-refs\")\n187\t\tif err != nil {\n188\t\t\treturn nil, \"\", err\n189\t\t}\n190\t\treturn decodeV2LSRefs(bytes.NewReader(data))\n191\t}\n192\t\n193\tfunc decodeV2LSRefs(r *bytes.Reader) ([]*plumbing.Reference, plumbing.ReferenceName, error) {\n194\t\treader := NewPacketReader(r)\n195\t\tvar refs []*plumbing.Reference\n196\t\tvar headTarget plumbing.ReferenceName\n197\t\tfor {\n198\t\t\tkind, payload, err := reader.ReadPacket()\n199\t\t\tif err != nil {\n200\t\t\t\treturn nil, \"\", err\n201\t\t\t}\n202\t\t\tif kind == PacketFlush {\n203\t\t\t\treturn refs, headTarget, nil\n204\t\t\t}\n205\t\t\tif kind != PacketData {\n206\t\t\t\treturn nil, \"\", fmt.Errorf(\"unexpected packet type %v in ls-refs response\", kind)\n207\t\t\t}\n208\t\t\tfields := strings.Fields(strings.TrimSpace(string(payload)))\n209\t\t\tif len(fields) < 2 {\n210\t\t\t\treturn nil, \"\", fmt.Errorf(\"malformed ls-refs response line %q\", payload)\n211\t\t\t}\n212\t\t\tif fields[0] == \"unborn\" {\n213\t\t\t\tcontinue\n214\t\t\t}\n215\t\t\thash := plumbing.NewHash(fields[0])\n216\t\t\tname := plumbing.ReferenceName(fields[1])\n217\t\t\tif name == plumbing.HEAD {\n218\t\t\t\t// HEAD is surfaced via headTarget only; not appended to the ref\n219\t\t\t\t// slice because it is a symbolic ref, matching v1 behavior where\n220\t\t\t\t// symrefs are filtered out by downstream RefHashMap.\n221\t\t\t\tfor _, attr := range fields[2:] {\n222\t\t\t\t\tif target, ok := strings.CutPrefix(attr, \"symref-target:\"); ok {\n223\t\t\t\t\t\theadTarget = plumbing.ReferenceName(target)\n224\t\t\t\t\t\tbreak\n225\t\t\t\t\t}\n226\t\t\t\t}\n\n... [92 lines truncated] ..."},"type":"attachment","uuid":"a786fe8e-589e-48f2-b13f-1089b45899ab","timestamp":"2026-05-18T14:28:14.143Z","userType":"external","entrypoint":"cli","cwd":"/Users/soph/Work/entire/devenv/git-sync","sessionId":"ff0a7d3f-e73b-48cc-a5d1-49b930a82fdf","version":"2.1.143","gitBranch":"soph/ssh-e2e-docker"}
{"parentUuid":"a786fe8e-589e-48f2-b13f-1089b45899ab","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/soph/Work/entire/devenv/git-sync/internal/gitproto/smarthttp.go","snippet":"1\tpackage gitproto\n2\t\n3\timport (\n4\t\t\"bytes\"\n5\t\t\"context\"\n6\t\t\"crypto/tls\"\n7\t\t\"fmt\"\n8\t\t\"io\"\n9\t\t\"mime\"\n10\t\t\"net/http\"\n11\t\t\"net/url\"\n12\t\t\"strings\"\n13\t\n14\t\t\"github.com/go-git/go-git/v6/plumbing/protocol/capability\"\n15\t)\n16\t\n17\tconst maxHTTPErrorBody = 64 * 1024\n18\t\n19\t// diagnosticHeaders carry trace/correlation IDs that operators of upstream\n20\t// services use to look up the failing request server-side. Surfaced in\n21\t// httpError so a 500 with an opaque body (e.g. \"Internal Server Error\") still\n22\t// gives the user something actionable to share when reporting the failure.\n23\tvar diagnosticHeaders = []string{\n24\t\t\"Cf-Ray\",\n25\t\t\"X-Request-Id\",\n26\t\t\"Request-Id\",\n27\t\t\"X-Trace-Id\",\n28\t\t\"X-Amz-Request-Id\",\n29\t\t\"X-Github-Request-Id\",\n30\t\t\"Server\",\n31\t\t\"Content-Type\",\n32\t}\n33\t\n34\t// httpError checks an HTTP response status and returns an error for non-2xx responses.\n35\tfunc httpError(res *http.Response) error {\n36\t\tif res.StatusCode >= http.StatusOK && res.StatusCode < http.StatusMultipleChoices {\n37\t\t\treturn nil\n38\t\t}\n39\t\tvar reason string\n40\t\tif res.Body != nil {\n41\t\t\tlimited := io.LimitReader(res.Body, maxHTTPErrorBody+1)\n42\t\t\tdata, err := io.ReadAll(limited)\n43\t\t\tif err == nil && len(data) > 0 {\n44\t\t\t\tif len(data) > maxHTTPErrorBody {\n45\t\t\t\t\tdata = append(data[:maxHTTPErrorBody], []byte(\"...\")...)\n46\t\t\t\t}\n47\t\t\t\treason = strings.TrimSpace(string(data))\n48\t\t\t}\n49\t\t}\n50\t\tvar diag []string\n51\t\tfor _, h := range diagnosticHeaders {\n52\t\t\tif v := res.Header.Get(h); v != \"\" {\n53\t\t\t\tdiag = append(diag, h+\"=\"+v)\n54\t\t\t}\n55\t\t}\n56\t\tif len(diag) > 0 {\n57\t\t\treturn fmt.Errorf(\"http %d: %s [%s] %s\", res.StatusCode, res.Request.URL.Redacted(), strings.Join(diag, \", \"), reason)\n58\t\t}\n59\t\treturn fmt.Errorf(\"http %d: %s %s\", res.StatusCode, res.Request.URL.Redacted(), reason)\n60\t}\n61\t\n62\t// StatsPhaseHeader is the HTTP header used to annotate requests with the\n63\t// current git-sync stats phase for round-trip tracking.\n64\tconst StatsPhaseHeader = \"X-Git-Sync-Stats-Phase\"\n65\t\n66\t// AuthMethod authorizes outbound HTTP requests for a remote. It is satisfied\n67\t// by *transporthttp.BasicAuth and *transporthttp.TokenAuth, whose Authorizer\n68\t// methods replaced the AuthMethod interface that go-git removed in v6 alpha.2.\n69\ttype AuthMethod interface {\n70\t\tAuthorizer(req *http.Request) error\n71\t}\n72\t\n73\t// HTTPConn represents a connection to a remote Git HTTP endpoint.\n74\ttype HTTPConn struct {\n75\t\tLabel       string\n76\t\tEndpointURL *url.URL\n77\t\tHTTP        *http.Client\n78\t\tAuth        AuthMethod\n79\t\n80\t\t// FollowInfoRefsRedirect, when true, rewrites Endpoint.Scheme and\n81\t\t// Endpoint.Host to the final URL returned by RequestInfoRefs after\n82\t\t// HTTP redirects. Subsequent PostRPC* calls then target the\n83\t\t// redirected host directly, matching vanilla git's smart-HTTP\n84\t\t// behaviour for discovery-aware servers that 307 /info/refs to a\n85\t\t// hosting replica. Endpoint.Path is never modified — it still\n86\t\t// contains the repo path. Off by default to preserve behaviour for\n87\t\t// callers that rely on Endpoint being stable.\n88\t\tFollowInfoRefsRedirect bool\n89\t\n90\t\t// ProgressOut is the destination for verbose sideband progress\n91\t\t// messages (\"Enumerating objects: ...\", \"Resolving deltas: ...\"\n92\t\t// streamed by upload-pack and receive-pack). Nil falls back to\n93\t\t// os.Stderr. Callers driving a live progress ticker can plug in a\n94\t\t// coordinated writer here so server-side progress lines don't\n95\t\t// clobber the in-place ticker frame.