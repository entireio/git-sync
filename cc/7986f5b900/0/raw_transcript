    RefKindTag,\n102\t\t\tLabel:      \"v1\",\n103\t\t\tSourceRef:  plumbing.NewTagReferenceName(\"v1\"),\n104\t\t\tTargetRef:  plumbing.NewTagReferenceName(\"v1\"),\n105\t\t\tSourceHash: source,\n106\t\t}, target, true)\n107\t\tif plan.Action != ActionUpdate {\n108\t\t\tt.Fatalf(\"expected update, got %s\", plan.Action)\n109\t\t}\n110\t\tif plan.Reason != \"11111111 -> 22222222 (replicate tag overwrite)\" {\n111\t\t\tt.Fatalf(\"unexpected reason: %s\", plan.Reason)\n112\t\t}\n113\t}\n114\t\n115\tfunc TestBuildReplicationPlansDoesNotMutateManaged(t *testing.T) {\n116\t\t// BuildReplicationPlans inserts prune-eligible orphan refs into a local\n117\t\t// copy of `managed`. Regression guard: it must not mutate the caller's map.\n118\t\torphan := plumbing.NewBranchReferenceName(\"stale\")\n119\t\tmain := plumbing.NewBranchReferenceName(\"main\")\n120\t\tmanaged := map[plumbing.ReferenceName]ManagedTarget{\n121\t\t\tmain: {Kind: RefKindBranch, Label: \"main\"},\n122\t\t}\n123\t\tdesired := map[plumbing.ReferenceName]DesiredRef{\n124\t\t\tmain: {\n125\t\t\t\tKind:       RefKindBranch,\n126\t\t\t\tLabel:      \"main\",\n127\t\t\t\tSourceRef:  main,\n128\t\t\t\tTargetRef:  main,\n129\t\t\t\tSourceHash: plumbing.NewHash(\"2222222222222222222222222222222222222222\"),\n130\t\t\t},\n131\t\t}\n132\t\ttargetRefs := map[plumbing.ReferenceName]plumbing.Hash{\n133\t\t\tmain:   plumbing.NewHash(\"1111111111111111111111111111111111111111\"),\n134\t\t\torphan: plumbing.NewHash(\"3333333333333333333333333333333333333333\"),\n135\t\t}\n136\t\n137\t\tplans, err := BuildReplicationPlans(desired, targetRefs, managed, PlanConfig{Prune: true})\n138\t\tif err != nil {\n139\t\t\tt.Fatalf(\"BuildReplicationPlans: %v\", err)\n140\t\t}\n141\t\n142\t\t// The returned plans should include the orphan delete...\n143\t\tvar sawDelete bool\n144\t\tfor _, p := range plans {\n145\t\t\tif p.TargetRef == orphan && p.Action == ActionDelete {\n146\t\t\t\tsawDelete = true\n147\t\t\t}\n148\t\t}\n149\t\tif !sawD