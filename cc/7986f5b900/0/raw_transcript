ates)\n203\t\t}\n204\t}\n205\t\n206\tfunc TestSampledCheckpointUnderLimit(t *testing.T) {\n207\t\tchain := make([]plumbing.Hash, 40)\n208\t\tfor i := range chain {\n209\t\t\tchain[i] = plumbing.NewHash(fmt.Sprintf(\"%040x\", i+1))\n210\t\t}\n211\t\tvar probes []int\n212\t\tbest, err := SampledCheckpointUnderLimit(chain, 4, 8, func(idx int) (bool, error) {\n213\t\t\tprobes = append(probes, idx)\n214\t\t\treturn idx > 19, nil\n215\t\t})\n216\t\tif err != nil {\n217\t\t\tt.Fatalf(\"SampledCheckpointUnderLimit: %v\", err)\n218\t\t}\n219\t\tif best < 12 || best > 19 {\n220\t\t\tt.Fatalf(\"expected a reasonable sampled checkpoint, got %d\", best)\n221\t\t}\n222\t\tif len(probes) > 6 {\n223\t\t\tt.Fatalf(\"expected fixed small probe count, got %d probes: %v\", len(probes), probes)\n224\t\t}\n225\t}\n226\t\n227\tfunc TestBuildDesiredRefsWithMappings(t *testing.T) {\n228\t\thash1 := plumbing.NewHash(\"1111111111111111111111111111111111111111\")\n229\t\thash2 := plumbing.NewHash(\"2222222222222222222222222222222222222222\")\n230\t\n231\t\tsourceRefs := map[plumbing.ReferenceName]plumbing.Hash{\n232\t\t\tplumbing.NewBranchReferenceName(\"main\"):    hash1,\n233\t\t\tplumbing.NewBranchReferenceName(\"develop\"): hash2,\n234\t\t}\n235\t\n236\t\ttests := []struct {\n237\t\t\tname        string\n\n... [1023 lines truncated] ..."},"type":"attachment","uuid":"8546856f-7480-4dcc-aa64-e13559469568","timestamp":"2026-05-03T18:58:39.034Z","userType":"external","entrypoint":"cli","cwd":"/Users/soph/Work/entire/devenv/git-sync","sessionId":"124cf89f-b950-42d0-8c90-1990b889f0bc","version":"2.1.123","gitBranch":"soph/prevent-double-fetch"}
{"parentUuid":"8546856f-7480-4dcc-aa64-e13559469568","isSidechain":false,"attachment":{"type":"edited_text_file","filename":"/Users/soph/Work/entire/devenv/git-sync/internal/planner/relay.go","snippet":"1\tpackage planner\n2\t\n3\timport (\n4\t\t\"github.com/go-git/go-git/v6/plumbing\"\n5\t)\n6\t\n7\t// RelayTargetPolicy captures only the target-side facts that affect planner\n8\t// relay eligibility decisions.\n9\ttype RelayTargetPolicy struct {\n10\t\tCapabilitiesKnown bool\n11\t\tNoThin            bool\n12\t}\n13\t\n14\t// SupportsReplicateRelay checks target-side capabilities required by\n15\t// replication mode before looking at planned ref actions.\n16\t//\n17\t// Replicate tolerates targets that advertise \"no-thin\" because our\n18\t// upload-pack client (gitproto.FetchPack) never requests the \"thin-pack\"\n19\t// capability, so the source never emits a thin pack. The relayed pack is\n20\t// always self-contained and safe to push to a no-thin receive-pack.\n21\t// If gitproto.FetchPack ever begins requesting thin-pack, this check must\n22\t// gain a matching fallback (omit the request, or explicitly advertise\n23\t// NoThin on the source request) when target.NoThin is set.\n24\tfunc SupportsReplicateRelay(target RelayTargetPolicy) (bool, string) {\n25\t\tif !target.CapabilitiesKnown {\n26\t\t\treturn false, \"replicate-missing-target-capabilities\"\n27\t\t}\n28\t\tif target.NoThin {\n29\t\t\treturn true, \"replicate-target-capable-no-thin\"\n30\t\t}\n31\t\treturn true, \"replicate-target-capable\"\n32\t}\n33\t\n34\t// CanBootstrapRelay checks whether all desired target refs are absent on the target,\n35\t// making a bootstrap relay possible.\n36\tfunc CanBootstrapRelay(\n37\t\tforce, prune bool,\n38\t\tdesired map[plumbing.ReferenceName]DesiredRef,\n39\t\ttargetRefs map[plumbing.ReferenceName]plumbing.Hash,\n40\t) (bool, string) {\n41\t\tif force || prune {\n42\t\t\treturn false, \"bootstrap-disabled-by-force-or-prune\"\n43\t\t}\n44\t\tif len(desired) == 0 {\n45\t\t\treturn false, \"bootstrap-no-managed-refs\"\n46\t\t}\n47\t\tfor targetRef := range desired {\n48\t\t\tif !targetRefs[targetRef].IsZero() {\n49\t\t\t\treturn false, \"bootstrap-target-ref-exists\"\n50\t\t\t}\n51\t\t}\n52\t\treturn true, \"empty-target-managed-refs\"\n53\t}\n54\t\n55\t// CanIncrementalRelay checks whether all plans are eligible for the incremental\n56\t// relay fast-path (fast-forward branch updates + new tag creates).\n57\tfunc CanIncrementalRelay(force, prune, dryRun bool, plans []BranchPlan, target RelayTargetPolicy) (bool, string) {\n58\t\tif force || prune || dryRun {\n59\t\t\treturn false, \"incremental-disabled-by-force-prune-or-dry-run\"\n60\t\t}\n61\t\tif len(plans) == 0 {\n62\t\t\treturn false, \"incremental-no-plans\"\n63\t\t}\n64\t\tif !target.CapabilitiesKnown {\n65\t\t\treturn false, \"incremental-missing-target-capabilities\"\n66\t\t}\n67\t\tif target.NoThin {\n68\t\t\treturn false, \"incremental-target-no-thin\"\n69\t\t}\n70\t\n71\t\tfor _, plan := range plans {\n72\t\t\tswitch plan.Kind {\n73\t\t\tcase RefKindBranch:\n74\t\t\t\tif !plan.SourceRef.IsBranch() || !plan.TargetRef.IsBranch() {\n75\t\t\t\t\treturn false, \"incremental-non-branch-mapping\"\n76\t\t\t\t}\n77\t\t\t\tif plan.Action != ActionUpdate {\n78\t\t\t\t\treturn false, \"incremental-branch-action-not-update\"\n79\t\t\t\t}\n80\t\t\t\tif plan.TargetHash.IsZero() {\n81\t\t\t\t\treturn false, \"incremental-branch-target-missing\"\n82\t\t\t\t}\n83\t\t\tcase RefKindTag:\n84\t\t\t\tif !plan.SourceRef.IsTag() || !plan.TargetRef.IsTag() {\n85\t\t\t\t\treturn false, \"incremental-non-tag-mapping\"\n86\t\t\t\t}\n87\t\t\t\tif plan.Action != ActionCreate {\n88\t\t\t\t\treturn false, \"incremental-tag-action-not-create\"\n89\t\t\t\t}\n90\t\t\tdefault:\n91\t\t\t\treturn false, \"incremental-unsupported-ref-kind\"\n92\t\t\t}\n93\t\t}\n94\t\treturn true, \"fast-forward-branch-or-tag-create\"\n95\t}\n96\t\n97\t// CanFullTagCreateRelay checks whether all plans are tag creates, eligible for\n98\t// a full-pack tag relay.\n99\tfunc CanFullTagCreateRelay(plans []BranchPlan) (bool, string) {\n100\t\tif len(plans) == 0 {\n101\t\t\treturn false, \"incremental-no-plans\"\n102\t\t}\n103\t\tfor _, plan := range plans {\n104\t\t\tif plan.Kind != RefKindTag {\n105\t\t\t\treturn false, \"incremental-tag-relay-non-tag-plan\"\n106\t\t\t}\n107\t\t\tif !plan.SourceRef.IsTag() || !plan.TargetRef.IsTag() {\n108\t\t\t\treturn false, \"incremental-tag-relay-non-tag-mapping\"\n109\t\t\t}\n110\t\t\tif plan.Action != ActionCreate {\n111\t\t\t\treturn false, \"incremental-tag-relay-tag-action-not-create\"\n112\t\t\t}\n113\t\t}\n114\t\treturn true, \"tag-create-full-pack\"\n115\t}\n116\t\n117\t// RelayFallbackReason returns the reason why relay was not used.\n118\tfunc RelayFallbackReason(force, prune, dryRun bool, plans []BranchPlan, target RelayTargetPolicy) string {\n119\t\tif ok, reason := CanIncrementalRelay(force, prune, dryRun, plans, target); ok {\n120\t\t\treturn reason\n121\t\t}\n122\t\t_, reason := CanFullTagCreateRelay(plans)\n123\t\treturn reason\n124\t}\n125\t\n126\t// CanReplicateRelay checks whether replication mode can execute as a relay-only\n127\t// overwrite sync against the target.\n128\tfunc CanReplicateRelay(plans []BranchPlan) (bool, string) {\n129\t\tfor _, plan := range plans {\n130\t\t\tswitch plan.Kind {\n131\t\t\tcase RefKindBranch:\n132\t\t\t\tif !plan.SourceRef.IsBranch() || !plan.TargetRef.IsBranch() {\n133\t\t\t\t\treturn false, \"replicate-non-branch-mapping\"\n134\t\t\t\t}\n135\t\t\t\tif plan.Action != ActionCreate && plan.Action != ActionUpdate {\n136\t\t\t\t\treturn false, \"replicate-branch-action-not-create-or-update\"\n137\t\t\t\t}\n138\t\t\tcase RefKindTag:\n139\t\t\t\tif !plan.SourceRef.IsTag() || !plan.TargetRef.IsTag() {\n140\t\t\t\t\treturn false, \"replicate-non-tag-mapping\"\n141\t\t\t\t}\n142\t\t\t\tif plan.Action != ActionCreate && plan.Action != ActionUpdate {\n143\t\t\t\t\treturn false, \"replicate-tag-action-not-c