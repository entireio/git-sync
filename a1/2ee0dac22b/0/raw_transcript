355\t// fast-forward ancestry check. This prevents full graph walks on very\n356\t// large histories (issue #16). Set high enough to avoid false negatives\n357\t// on real repos — even the Linux kernel has ~1.3M commits.\n358\tconst MaxAncestryDepth = 2_000_000\n359\t\n360\t// ErrAncestryDepthExceeded is returned when ReachesCommit exceeds MaxAncestryDepth.\n361\tvar ErrAncestryDepthExceeded = errors.New(\"ancestry check exceeded depth limit\")\n362\t\n363\t// ReachesCommit checks whether the commit at startHash has targetHash as an\n364\t// ancestor, bounded to MaxAncestryDepth commits to prevent degenerate walks.\n365\tfunc ReachesCommit(store storer.EncodedObjectStorer, startHash, targetHash plumbing.Hash) (bool, error) {\n366\t\tif startHash == targetHash {\n367\t\t\treturn true, nil\n368\t\t}\n369\t\n370\t\tstart, err := object.GetCommit(store, startHash)\n371\t\tif err != nil {\n372\t\t\treturn false, fmt.Errorf(\"load source commit %s: %w\", startHash, err)\n373\t\t}\n374\t\n375\t\tseen := map[plumbing.Hash]struct{}{}\n376\t\tstack := []*object.Commit{start}\n377\t\n378\t\tfor len(stack) > 0 {\n379\t\t\tif len(seen) >= MaxAncestryDepth {\n380\t\t\t\treturn false, ErrAncestryDepthExceeded\n381\t\t\t}\n382\t\t\tcurrent := stack[len(stack)-1]\n383\t\t\tstack = stack[:len(stack)-1]\n384\t\t\tif _, ok := seen[current.Hash]; ok {\n385\t\t\t\tcontinue\n386\t\t\t}\n387\t\t\tseen[current.Hash] = struct{}{}\n388\t\n389\t\t\tfor _, parentHash := range current.ParentHashes {\n390\t\t\t\tif parentHash == targetHash {\n391\t\t\t\t\treturn true, nil\n392\t\t\t\t}\n393\t\t\t\tif _, ok := seen[parentHash]; ok {\n394\t\t\t\t\tcontinue\n395\t\t\t\t}\n396\t\t\t\tparent, err := object.GetCommit(store, parentHash)\n397\t\t\t\tif err != nil {\n398\t\t\t\t\tif errors.Is(err, plumbing.ErrObjectNotFound) {\n399\t\t\t\t\t\tcontinue\n400\t\t\t\t\t}\n401\t\t\t\t\treturn false, fmt.Errorf(\"load parent commit %s: %w\", parentHash, err)\n402\t\t\t\t}\n403\t\t\t\tstack = append(stack, paren