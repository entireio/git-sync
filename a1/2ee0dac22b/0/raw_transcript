\t\t\t\tLabel:      short,\n45\t\t\t\tSourceRef:  sourceRef,\n46\t\t\t\tTargetRef:  targetRef,\n47\t\t\t\tSourceHash: hash,\n48\t\t\t}\n49\t\t\tmanaged[targetRef] = ManagedTarget{Kind: kind, Label: short}\n50\t\t\treturn nil\n51\t\t}\n52\t\n53\t\tif len(cfg.Mappings) > 0 {\n54\t\t\t// Validate all mappings up front (issue #2, #3)\n55\t\t\tnormalized, err := validation.ValidateMappings(cfg.Mappings)\n56\t\t\tif err != nil {\n57\t\t\t\treturn nil, nil, fmt.Errorf(\"validate ref mappings: %w\", err)\n58\t\t\t}\n59\t\t\tfor _, nm := range normalized {\n60\t\t\t\tkind := RefKindFromName(nm.TargetRef)\n61\t\t\t\tif err := addManaged(nm.SourceRef, nm.TargetRef, kind, sourceRefs[nm.SourceRef]); err != nil {\n62\t\t\t\t\treturn nil, nil, err\n63\t\t\t\t}\n64\t\t\t}\n65\t\t} else {\n66\t\t\tbranches := BranchMapFromRefHashMap(sourceRefs)\n67\t\t\tselected := SelectBranches(branches, cfg.Branches)\n68\t\t\tfor branch, hash := range selected {\n69\t\t\t\trefName := plumbing.NewBranchReferenceName(branch)\n70\t\t\t\tif err := addManaged(refName, refName, RefKindBranch, hash); err != nil {\n71\t\t\t\t\treturn nil, nil, err\n72\t\t\t\t}\n73\t\t\t}\n74\t\t}\n75\t\n76\t\tif cfg.IncludeTags {\n77\t\t\tfor refName, hash := range sourceRefs {\n78\t\t\t\tif !refName.IsTag() {\n79\t\t\t\t\tcontinue\n80\t\t\t\t}\n81\t\t\t\tif err := addManaged(refName, refName, RefKindTag, hash); err != nil {\n82\t\t\t\t\treturn nil, nil, err\n83\t\t\t\t}\n84\t\t\t}\n85\t\t}\n86\t\n87\t\treturn desired, managed, nil\n88\t}\n89\t\n90\t// BuildPlans generates the action plans for each managed ref.\n91\tfunc BuildPlans(\n92\t\tstore storer.EncodedObjectStorer,\n93\t\tdesired map[plumbing.ReferenceName]DesiredRef,\n94\t\ttargetRefs map[plumbing.ReferenceName]plumbing.Hash,\n95\t\tmanaged map[plumbing.ReferenceName]ManagedTarget,\n96\t\tcfg PlanConfig,\n97\t) ([]BranchPlan, error) {\n98\t\tif cfg.Prune {\n99\t\t\tfor targetRef := range targetRefs {\n100\t\t\t\tif _, ok := managed[targetRef]; ok {\n101\t\t\t\t\tcontinue\n102\t\t\t\t}\n103\t\t\t\tswitch {\n104\t\t\t\tcase targetRef.IsTag() && cfg.IncludeTags:\n105\t\t\t\t\tmanaged[targetRef] = ManagedTarget{Kind: RefKindTag, Label: targetRef.Short()}\n106\t\t\t\tcase targetRef.IsBranch() && len(cfg.Mappings) == 0 && len(cfg.Branches) == 0:\n107\t\t\t\t\tmanaged[targetRef] = ManagedTarget{Kind: RefKindBranch, Label: targetRef.Short()}\n108\t\t\t\t}\n109\t\t\t}\n110\t\t}\n111\t\n112\t\ttargetNames := make([]plumbing.ReferenceName, 0, len(managed))\n113\t\tfor name := range managed {\n114\t\t\ttargetNames = append(targetNames, name)\n115\t\t}\n116\t\tsort.Slice(targetNames, func(i, j int) bool { return targetNames[i] < targetNames[j] })\n117\t\n118\t\tplans := make([]BranchPlan, 0, len(targetNames))\n119\t\tfor _, targetRef := range targetNames {\n120\t\t\tinfo := managed[targetRef]\n121\t\t\twant, existsInDesired := desired[targetRef]\n122\t\t\ttargetHash, existsOnTarget := targetRefs[targetRef]\n123\t\n124\t\t\tif !existsInDesired {\n125\t\t\t\tif cfg.Prune && existsOnTarget {\n126\t\t\t\t\tplans = append(plans, BranchPlan{\n127\t\t\t\t\t\tBranch:     info.Label,\n128\t\t\t\t\t\tTargetRef:  targetRef,\n129\t\t\t\t\t\tTargetHash: targetHash,\n130\t\t\t\t\t\tKind:       info.Kind,\n131\t\t\t\t\t\tAction:     ActionDelete,\n132\t\t\t\t\t\tReason:     ShortHash(targetHash) + \" -> <deleted>\",\n133\t\t\t\t\t})\n134\t\t\t\t}\n135\t\t\t\tcontinue\n136\t\t\t}\n137\t\n138\t\t\tif !existsOnTarget {\n139\t\t\t\tplans = append(plans, BranchPlan{\n140\t\t\t\t\tBranch:     want.Label,\n141\t\t\t\t\tSourceRef:  want.SourceRef,\n142\t\t\t\t\tTargetRef:  want.TargetRef,\n143\t\t\t\t\tSourceHash: want.SourceHash,\n144\t\t\t\t\tKind:       want.Kind,\n145\t\t\t\t\tAction:     ActionCreate,\n146\t\t\t\t\tReason:     ShortHash(want.SourceHash) + \" -> <new>\",\n147\t\t\t\t})\n148\t\t\t\tcontinue\n149\t\t\t}\n150\t\n151\t\t\tplan, err := PlanRef(store, want, targetHash, cfg.Force)\n152\t\t\tif err != nil {\n153\t\t\t\treturn nil, err\n154\t\t\t}\n155\t\t\tplans = append(plans, plan)\n156\t\t}\n157\t\n158\t\tsort.Slice(plans, func(i, j int) bool {\n159\t\t\treturn plans[i].TargetRef.String() < plans[j].TargetRef.String()\n160\t\t})\n161\t\treturn plans, nil\n162\t}\n163\t\n164\t// BuildReplicationPlans generates overwrite-oriented plans for replication mode.\n165\t// Divergent refs are updated directly rather than blocked.\n166\t//\n167\t//nolint:unparam // error return kept for API consistency with BuildPlans\n168\tfunc BuildReplicationPlans(\n169\t\tdesired map[plumbing.ReferenceName]DesiredRef,\n170\t\ttargetRefs map[plumbing.ReferenceName]plumbing.Hash,\n171\t\tmanaged map[plumbing.ReferenceName]ManagedTarget,\n172\t\tcfg PlanConfig,\n173\t) ([]BranchPlan, error) {\n174\t\tmanaged = copyManagedTargets(managed)\n175\t\tif cfg.Prune {\n176\t\t\tfor targetRef := range targetRefs {\n177\t\t\t\tif _, ok := managed[targetRef]; ok {\n178\t\t\t\t\tcontinue\n179\t\t\t\t}\n180\t\t\t\tswitch {\n181\t\t\t\tcase targetRef.IsTag() && cfg.IncludeTags:\n182\t\t\t\t\tmanaged[targetRef] = ManagedTarget{Kind: RefKindTag, Label: targetRef.Short()}\n183\t\t\t\tcase targetRef.IsBranch() && len(cfg.Mappings) == 0 && len(cfg.Branches) == 0:\n184\t\t\t\t\tmanaged[targetRef] = ManagedTarget{Kind: RefKindBranch, Label: targetRef.Short()}\n185\t\t\t\t}\n186\t\t\t}\n187\t\t}\n188\t\n189\t\ttargetNames := make([]plumbing.ReferenceName, 0, len(managed))\n190\t\tfor name := range managed {\n191\t\t\ttargetNames = append(targetNames, name)\n192\t\t}\n193\t\tsort.Slice(targetNames, func(i, j int) bool { return targetNames[i] < targetNames[j] })\n194\t\n195\t\tplans := make([]BranchPlan, 0, len(targetNames))\n196\t\tfor _, targetRef := range targetNames {\n197\t\t\tinfo := managed[targetRef]\n198\t\t\twant, existsInDesired := desired[targetRef]\n199\t\t\ttargetHash, existsOnTarget := targetRefs[targetRef]\n200\t\n201\t\t\tif !existsInDesired {\n202\t\t\t\tif cfg.Prune && existsOnTarget {\n203\t\t\t\t\tplans = append(plans, BranchPlan{\n204\t\t\t\t\t\tBranch:     info.Label,\n205\t\t\t\t\t\tTargetRef:  targetRef,\n206\t\t\t\t\t\tTargetHash: targetHash,\n207\t\t\t\t\t\tKind:       info.Kind,\n208\t\t\t\t\t\tAction:     ActionDelete,\n209\t\t\t\t\t\tReason:     ShortHash(targetHash) + \" -> <deleted>\",\n210\t\t\t\t\t})\n211\t\t\t\t}\n212\t\t\t\tcontinue\n213\t\t\t}\n214\t\n215\t\t\tplans = append(plans, PlanReplicationRef(want, targetHash, existsOnTarget))\n216\t\t}\n217\t\n218\t\tsort.Slice(plans, func(i, j int) bool {\n219\t\t\treturn plans[i].TargetRef.String() < plans[j].TargetRef.String()\n220\t\t})\n221\t\treturn plans, nil\n222\t}\n223\t\n224\tfunc copyManagedTargets(input map[plumbing.ReferenceName]ManagedTarget) map[plumbing.ReferenceName]ManagedTarget {\n225\t\tout := make(map[plumbing.ReferenceName]ManagedTarget, len(input))\n226\t\tfor k, v := range input {\n227\t\t\tout[k] = v\n228\t\t}\n229\t\treturn out\n230\t}\n231\t\n232\t// BuildBootstrapPlans creates plans for an empty-target bootstrap.\n233\tfunc BuildBootstrapPlans(\n234\t\tdesired map[plumbing.ReferenceName]DesiredRef,\n235\t\ttargetRefs map[plumbing.ReferenceName]plumbing.Hash,\n236\t) ([]BranchPlan, error) {\n237\t\ttargetNames := make([]plumbing.ReferenceName, 0, len(desired))\n238\t\tfor _, want := range desired {\n239\t\t\ttargetNames = append(targetNames, want.TargetRef)\n240\t\t}\n241\t\tsort.Slice(targetNames, func(i, j int) bool { return targetNames[i] < targetNames[j] })\n242\t\n243\t\tplans := make([]BranchPlan, 0, len(targetNames))\n244\t\tfor _, targetRef := range targetNames {\n245\t\t\ttargetHash := targetRefs[targetRef]\n246\t\t\tif !targetHash.IsZero() {\n247\t\t\t\treturn nil, fmt.Errorf(\"target ref %s already exists; use sync for non-bootstrap runs\", targetRef)\n248\t\t\t}\n249\t\t\twant := desired[targetRef]\n250\t\t\tplans = append(plans, BranchPlan{\n251\t\t\t\tBranch:     want.Label,\n252\t\t\t\tSourceRef:  want.SourceRef,\n253\t\t\t\tTargetRef:  want.TargetRef,\n254\t\t\t\tSourceHash: want.SourceHash,\n255\t\t\t\tTargetHash: plumbing.ZeroHash,\n256\t\t\t\tKind:       want.Kind,\n257\t\t\t\tAction:     ActionCreate,\n258\t\t\t\tReason:     fmt.Sprintf(\"create %s at %s\", want.TargetRef, ShortHash(want.SourceHash)),\n259\t\t\t})\n260\t\t}\n261\t\treturn plans, nil\n262\t}\n263\t\n264\t// PlanRef determines the action for a single ref that exists on both source and target.\n265\tfunc PlanRef(store storer.EncodedObjectStorer, want DesiredRef, targetHash plumbing.Hash, force bool) (BranchPlan, error) {\n266\t\tplan := BranchPlan{\n267\t\t\tBranch:     want.Label,\n268\t\t\tSourceRef:  want.SourceRef,\n269\t\t\tTargetRef:  want.TargetRef,\n270\t\t\tSourceHash: want.SourceHash,\n271\t\t\tTargetHash: targetHash,\n272\t\t\tKind:       want.Kind,\n273\t\t}\n274\t\n275\t\tif want.SourceHash == targetHash {\n276\t\t\tplan.Action = ActionSkip\n277\t\t\tplan.Reason = ShortHash(want.SourceHash) + \" already current\"\n278\t\t\treturn plan, nil\n279\t\t}\n280\t\n281\t\tif want.Kind == RefKindTag {\n282\t\t\tif force {\n283\t\t\t\tplan.Action = ActionUpdate\n284\t\t\t\tplan.Reason = ShortHash(targetHash) + \" -> \" + ShortHash(want.SourceHash) + \" (force tag update)\"\n285\t\t\t\treturn plan, nil\n286\t\t\t}\n287\t\t\tplan.Action = ActionBlock\n288\t\t\tplan.Reason = ShortHash(targetHash) + \" differs from \" + ShortHash(want.SourceHash) + \"; use --force to retarget tag\"\n289\t\t\treturn plan, nil\n290\t\t}\n291\t\n292\t\tisFF, err := ReachesCommit(store, want.SourceHash, targetHash)\n293\t\tif err != nil {\n294\t\t\tif errors.Is(err, ErrAncestryDepthExceeded) {\n295\t\t\t\t// Can't prove fast-forward within depth limit — block with explanation.\n296\t\t\t\tplan.Action = ActionBlock\n297\t\t\t\tplan.Reason = \"ancestry check for \" + want.TargetRef.String() + \" exceeded depth limit; use --force if this is a valid fast-forward\"\n298\t\t\t\treturn plan, nil\n299\t\t\t}\n300\t\t\treturn plan, fmt.Errorf(\"check fast-forward for %s: %w\", want.TargetRef, err)\n301\t\t}\n302\t\t