%v\", err)\n251\t\t}\n252\t\tif sourceHead.Hash() != targetHead.Hash() {\n253\t\t\tt.Fatalf(\"expected target head %s to match source head %s\", targetHead.Hash(), sourceHead.Hash())\n254\t\t}\n255\t}\n256\t\n257\tfunc TestRun_Replicate_SubcommandRejectsForce(t *testing.T) {\n258\t\terr := run(context.Background(), []string{\n259\t\t\tmodeReplicate,\n260\t\t\t\"--force\",\n261\t\t\t\"http://127.0.0.1:1/source.git\",\n262\t\t\t\"http://127.0.0.1:1/target.git\",\n263\t\t})\n264\t\tif err == nil {\n265\t\t\tt.Fatal(\"expected replicate --force to be rejected\")\n266\t\t}\n267\t\tif !strings.Contains(err.Error(), \"replicate does not support --force\") {\n268\t\t\tt.Fatalf(\"unexpected error: %v\", err)\n269\t\t}\n270\t}\n271\t\n272\tfunc TestRun_Fetch_SourceFollowInfoRefsRedirectFlag(t *testing.T) {\n273\t\tsourceRepo, sourceFS := newSourceRepo(t)\n274\t\tmakeCommits(t, sourceRepo, sourceFS, 1)\n275\t\n276\t\tsourceServer := newSmartHTTPRepoServer(t, sourceRepo)\n277\t\tdefer sourceServer.Close()\n278\t\n279\t\tentry := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n280\t\t\tswitch {\n281\t\t\tcase r.Method == http.MethodGet && r.URL.Path == sourceServer.repoPath+\"/info/refs\":\n282\t\t\t\thttp.Redirect(w, r, sourceServer.server.URL+r.URL.Path+\"?\"+r.URL.RawQuery, http.StatusTemporaryRedirect)\n283\t\t\tcase r.Method == http.MethodPost:\n284\t\t\t\thttp.Error(w, \"entry domain rejects packs\", http.StatusMethodNotAllowed)\n285\t\t\tdefault:\n286\t\t\t\thttp.NotFound(w, r)\n287\t\t\t}\n288\t\t}))\n289\t\tdefer entry.Close()\n290\t\n291\t\toutput, err := captureStdout(func() error {\n292\t\t\treturn run(context.Background(), []string{\n293\t\t\t\t\"fetch\",\n294\t\t\t\t\"--source-follow-info-refs-redirect\",\n295\t\t\t\t\"--branch\", testBranch,\n296\t\t\t\t\"--json\",\n297\t\t\t\tentry.URL + sourceServer.repoPath,\n298\t\t\t})\n299\t\t})\n300\t\tif err != nil {\n301\t\t\tt.Fatalf(\"run fetch: %v\", err)\n302\t\t}\n303\t\n304\t\tvar result map[string]any\n305\t\tif err := json.Unmarshal([]byte(output), &result); err != nil {\n306\t\t\tt.Fatalf(\"decode fetch json: %v\\noutput=%s\", err, output)\n307\t\t}\n308\t\tif got, ok := result[\"fetchedObjects\"].(float64); !ok || got == 0 {\n309\t\t\tt.Fatalf(\"expected fetched objects from redirected source, got %#v\", result[\"fetchedObjects\"])\n310\t\t}\n311\t}\n312\t\n313\tfunc captureStdout(fn func() error) (string, error) {\n314\t\told := os.Stdout\n315\t\tr, w, err := os.Pipe()\n316\t\tif err != nil {\n317\t\t\treturn \"\", err\n318\t\t}\n319\t\tos.Stdout = w\n320\t\tdefer func() { os.Stdout = old }()\n321\t\n322\t\trunErr := fn()\n323\t\t_ = w.Close()\n324\t\n325\t\tvar buf bytes.Buffer\n326\t\tif _, err := io.Copy(&buf, r); err != nil {\n327\t\t\treturn \"\", err\n328\t\t}\n329\t\t_ = r.Close()\n330\t\treturn strings.TrimSpace(buf.String()), runErr\n331\t}\n332\t\n333\tfunc newSourceRepo(t *testing.T) (*git.Repository, billy.Filesystem) {\n334\t\tt.Helper()\n335\t\n336\t\tfs := memfs.New()\n337\t\trepo, err := git.Init(memory.NewStorage(), git.WithWorkTree(fs))\n338\t\tif err != nil {\n339\t\t\tt.Fatalf(\"init source repo: %v\", err)\n340\t\t}\n341\t\n342\t\treturn repo, fs\n343\t}\n344\t\n345\tfunc makeCommits(t *testing.T, repo *git.Repository, fs billy.Filesystem, count int) {\n346\t\tt.Helper()\n347\t\n348\t\twt, err := repo.Worktree()\n349\t\tif err != nil {\n350\t\t\tt.Fatalf(\"open worktree: %v\", err)\n351\t\t}\n352\t\n353\t\tfor i := range count {\n354\t\t\tcontent := strings.Repeat(fmt.Sprintf(\"line %d %d\\n\", i, time.Now().UnixNano()), 24)\n355\t\t\tfile, err := fs.Create(\"tracked.txt\")\n356\t\t\tif err != nil {\n357\t\t\t\tt.Fatalf(\"create file: %v\", err)\n358\t\t\t}\n359\t\t\tif _, err := io.WriteString(file, content); err != nil {\n360\t\t\t\tt.Fatalf(\"write file: %v\", err)\n361\t\t\t}\n362\t\t\tif err := file.Close(); err != nil {\n363\t\t\t\tt.Fatalf(\"close file: %v\", err)\n364\t\t\t}\n365\t\n366\t\t\tif _, err := wt.Add(\"tracked.txt\"); err != nil {\n367\t\t\t\tt.Fatalf(\"add file: %v\", err)\n368\t\t\t}\n369\t\n370\t\t\t_, err = wt.Commit(fmt.Sprintf(\"commit %d\", i), &git.CommitOptions{\n371\t\t\t\tAuthor:    &objectSignature,\n372\t\t\t\tCommitter: &objectSignature,\n373\t\t\t})\n374\t\t\tif err != nil {\n375\t\t\t\tt.Fatalf(\"commit: %v\", err)\n376\t\t\t}\n377\t\t}\n378\t}\n379\t\n380\tvar objectSignature = signature()\n381\t\n382\tfunc signature() object.Signature {\n383\t\treturn object.Signature{\n384\t\t\tName:  \"test\",\n385\t\t\tEmail: \"test@example.com\",\n386\t\t\tWhen:  time.Unix(1, 0).UTC(),\n387\t\t}\n388\t}\n389\t\n390\ttype smartHTTPRepoServer struct {\n391\t\tt        *testing.T\n392\t\tserver   *httptest.Server\n393\t\trepo     *git.Repository\n394\t\trepoPath string\n395\t\n396\t\tmu           sync.Mutex\n397\t\treceivePacks int\n398\t\tthinCapable  bool\n399\t}\n400\t\n401\tfunc newSmartHTTPRepoServer(t *testing.T, repo *git.Repository) *smartHTTPRepoServer {\n402\t\tt.Helper()\n403\t\n404\t\ts := &smartHTTPRepoServer{\n405\t\t\tt:           t,\n406\t\t\trepo:        repo,\n407\t\t\trepoPath:    \"/repo.git\",\n408\t\t\tthinCapable: true,\n409\t\t}\n410\t\ts.server = httptest.NewServer(http.HandlerFunc(s.handle))\n411\t\treturn s\n412\t}\n413\t\n414\tfunc (s *smartHTTPRepoServer) Close() {\n415\t\ts.server.Close()\n416\t}\n417\t\n418\tfunc (s *smartHTTPRepoServer) RepoURL() string {\n419\t\treturn s.server.URL + s.repoPath\n420\t}\n421\t\n422\tfunc (s *smartHTTPRepoServer) Count(service string) int {\n423\t\ts.mu.Lock()\n424\t\tdefer s.mu.Unlock()\n425\t\tif service == \"git-receive-pack\" {\n426\t\t\treturn s.receivePacks\n427\t\t}\n428\t\treturn 0\n429\t}\n430\t\n431\tfunc (s *smartHTTPRepoServer) handle(w http.ResponseWriter, r *http.Request) {\n432\t\tswitch {\n433\t\tcase r.Method == http.MethodGet && r.URL.Path == s.repoPath+\"/info/refs\":\n434\t\t\ts.handleInfoRefs(w, r)\n435\t\tcase r.Method == http.MethodPost && r.URL.Path == s.repoPath+\"/gi