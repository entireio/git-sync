ok {\n457\t\t\treturn nil\n458\t\t}\n459\t\tif seen[hash] {\n460\t\t\treturn nil\n461\t\t}\n462\t\tseen[hash] = true\n463\t\n464\t\tobj, err := store.EncodedObject(plumbing.AnyObject, hash)\n465\t\tif err != nil {\n466\t\t\tif errors.Is(err, plumbing.ErrObjectNotFound) {\n467\t\t\t\t// Reachable from a target-ref have via the source server's\n468\t\t\t\t// pack-prune; the target already has it, so it stays out\n469\t\t\t\t// of the push.\n470\t\t\t\treturn nil\n471\t\t\t}\n472\t\t\treturn fmt.Errorf(\"load object %s: %w\", hash, err)\n473\t\t}\n474\t\n475\t\tswitch obj.Type() {\n476\t\tcase plumbing.CommitObject:\n477\t\t\tcommit, err := object.GetCommit(store, hash)\n478\t\t\tif err != nil {\n479\t\t\t\treturn fmt.Errorf(\"load commit %s: %w\", hash, err)\n480\t\t\t}\n481\t\t\tif err := collectObjects(store, commit.TreeHash, haves, seen, out); err != nil {\n482\t\t\t\treturn err\n483\t\t\t}\n484\t\t\tfor _, ph := range commit.ParentHashes {\n485\t\t\t\tif err := collectObjects(store, ph, haves, seen, out); err != nil {\n486\t\t\t\t\treturn err\n487\t\t\t\t}\n488\t\t\t}\n489\t\tcase plumbing.TreeObject:\n490\t\t\ttree, err := object.GetTree(store, hash)\n491\t\t\tif err != nil {\n492\t\t\t\treturn fmt.Errorf(\"load tree %s: %w\", hash, err)\n493\t\t\t}\n494\t\t\tfor _, entry := range tree.Entries {\n495\t\t\t\tif err := collectObjects(store, entry.Hash, haves, seen, out); err != nil {\n496\t\t\t\t\treturn err\n497\t\t\t\t}\n498\t\t\t}\n499\t\tcase plumbing.TagObject:\n500\t\t\ttag, err := object.GetTag(store, hash)\n501\t\t\tif err != nil {\n502\t\t\t\treturn fmt.Errorf(\"load tag %s: %w\", hash, err)\n503\t\t\t}\n504\t\t\tif err := collectObjects(store, tag.Target, haves, seen, out); err != nil {\n505\t\t\t\treturn err\n506\t\t\t}\n507\t\tcase plumbing.BlobObject:\n508\t\t\t// Blobs are leaf objects — nothing to recurse into.\n509\t\tcase plumbing.InvalidObject, plumbing.OFSDeltaObject, plumbing.REFDeltaObject, plumbing.AnyObject:\n510\t\t\treturn fmt.Errorf(\"unsu