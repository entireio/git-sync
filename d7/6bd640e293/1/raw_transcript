t-upload-pack\":\n436\t\t\ts.handleUploadPack(w, r)\n437\t\tcase r.Method == http.MethodPost && r.URL.Path == s.repoPath+\"/git-receive-pack\":\n438\t\t\ts.handleReceivePack(w, r)\n439\t\tdefault:\n440\t\t\thttp.NotFound(w, r)\n441\t\t}\n442\t}\n443\t\n444\tfunc (s *smartHTTPRepoServer) handleInfoRefs(w http.ResponseWriter, r *http.Request) {\n445\t\tservice := r.URL.Query().Get(\"service\")\n446\t\tif service != transport.UploadPackService && service != transport.ReceivePackService {\n447\t\t\thttp.Error(w, \"missing service\", http.StatusBadRequest)\n448\t\t\treturn\n449\t\t}\n450\t\n451\t\tvar buf bytes.Buffer\n452\t\tif err := transport.AdvertiseRefs(r.Context(), s.repo.Storer, &buf, service, false); err != nil {\n453\t\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n454\t\t\treturn\n455\t\t}\n456\t\tif service == transport.ReceivePackService && s.thinCapable {\n457\t\t\trewritten, err := rewriteReceivePackAdvertisement(buf.Bytes(), func(caps *capability.List) {\n458\t\t\t\tcaps.Delete(capability.Capability(\"no-thin\"))\n459\t\t\t})\n460\t\t\tif err != nil {\n461\t\t\t\ts.t.Fatalf(\"rewrite receive-pack advertisement: %v\", err)\n462\t\t\t}\n463\t\t\tbuf.Reset()\n464\t\t\t_, _ = buf.Write(rewritten)\n465\t\t}\n466\t\n467\t\tw.Header().Set(\"Content-Type\", fmt.Sprintf(\"application/x-%s-advertisement\", service))\n468\t\tif _, err := w.Write(buf.Bytes()); err != nil {\n469\t\t\ts.t.Fatalf(\"write advertised refs: %v\", err)\n470\t\t}\n471\t}\n472\t\n473\tfunc rewriteReceivePackAdvertisement(data []byte, mutate func(*capability.List)) ([]byte, error) {\n474\t\tar := packp.NewAdvRefs()\n475\t\tif err := ar.Decode(bytes.NewReader(data)); err == nil {\n476\t\t\tmutate(ar.Capabilities)\n477\t\t\tvar buf bytes.Buffer\n478\t\t\tif err := ar.Encode(&buf); err != nil {\n479\t\t\t\treturn nil, err\n480\t\t\t}\n481\t\t\treturn buf.Bytes(), nil\n482\t\t}\n483\t\n484\t\trd := bytes.NewReader(data)\n485\t\tvar smart packp.SmartReply\n486\t\tif err := smart.Dec